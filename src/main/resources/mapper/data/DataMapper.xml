<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kcc.groo.data.dao.IDataRepository">

<select id="countReviewsByUserId" parameterType="string" resultType="int">
<![CDATA[
SELECT COUNT(*) FROM reviews WHERE user_id=#{userId}
]]>
</select>

<select id="countScrapBooksByUserId" parameterType="string" resultType="int">
<![CDATA[
SELECT COUNT(*) FROM book WHERE user_id=#{userId};
]]>
</select>

<select id="countLikesReviewsByUserId" parameterType="string" resultType="int">
<![CDATA[
SELECT COUNT(*) FROM likes WHERE user_id=#{userId};
]]>
</select>

<select id="getCategoryList" parameterType="string" resultType="string">
<![CDATA[
SELECT category FROM reviews WHERE user_id=#{userId}
]]>
</select>

<select id="getStatisticsByCategories" parameterType="string" resultType="int">
<![CDATA[
SELECT COUNT(*) FROM reviews WHERE user_id=#{userId} AND category=#{category}
]]>
</select>

</mapper>
