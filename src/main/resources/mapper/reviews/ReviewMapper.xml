<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kcc.groo.review.dao.IReviewRepository">

<resultMap id="reviewMap" type="com.kcc.groo.review.data.model.Review">
<id property="reviewId" column="review_id"/>
<result property="ISBN" column="ISBN"/>
<result property="reviewTitle" column="review_title"/>
<result property="reviewContent" column="review_content"/>
<result property="viewCnt" column="view_cnt"/>
<result property="secret" column="secret"/>
<result property="status" column="status"/>
<result property="temporary" column="temporary"/>
<result property="createdAt" column="created_at"/>
<result property="updatedAt" column="updated_at"/>
<result property="userId" column="user_id"/>
<result property="codeId" column="code_id"/>
</resultMap>

<!-- CREATE -->
<insert id="insertReview" parameterType="com.kcc.groo.review.data.model.Review">
<![CDATA[
INSERT INTO reviews (
            ISBN, review_title, review_content, view_cnt,
            secret, status, temporary, created_at,
            user_id, code_id
        )
        VALUES (
            #{ISBN}, #{reviewTitle}, #{reviewContent}, 0,
            #{secret}, TRUE, #{temporary}, NOW(),
            #{userId}, #{codeId}
        )
]]>
</insert>
</mapper>